flowchart LR
    subgraph INPUT["Regulatorische Quellen"]
        direction LR
        MDR["MDR<br/>2017/745"]
        IVDR["IVDR<br/>2017/746"]
        AIACT["EU-KI-Gesetz<br/>2024/1689"]
